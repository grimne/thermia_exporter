{
  "uid": "thermia-heatpump",
  "title": "Thermia Heat Pump",
  "description": "Ground source (bedrock/geothermal) heat pump metrics from thermia-exporter",
  "tags": [
    "thermia",
    "heatpump",
    "geothermal"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "5m",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "DS_THERMIA",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "heatpump",
        "label": "Heat pump",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_THERMIA}"
        },
        "query": {
          "query": "label_values(thermia_online, heatpump_name)",
          "refId": "var"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Heat pump",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_THERMIA}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ONLINE",
                  "color": "green"
                },
                "0": {
                  "text": "OFFLINE",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_THERMIA}"
          },
          "expr": "max by(heatpump_name) (thermia_online{heatpump_name=~\"$heatpump\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Current activity",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_THERMIA}"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_THERMIA}"
          },
          "expr": "max by(heatpump_name, status) (thermia_operational_status_running{heatpump_name=~\"$heatpump\"}) == 1",
          "legendFormat": "{{status}}",
          "refId": "A",
          "instant": true,
          "range": false
